  client.println(".timer{font-size:48px; color:#ff4444; font-weight:bold;}");
  client.println(".timer.warning{color:#ff8800; animation: pulse 0.5s infinite;}");
  client.println(".timer.danger{color:#ff0000; animation: pulse 0.3s infinite;}");
  client.println("@keyframes pulse{0%,100%{opacity:1;}50%{opacity:0.5;}}");
  client.println(".progress{width:100%; height:20px; background:#333; border-radius:10px; overflow:hidden; margin:10px 0;}");
  client.println(".progress-bar{height:100%; background:linear-gradient(90deg,#00ff00,#ffff00,#ff0000); transition:width 1s linear;}");
  client.println(".score{font-size:24px; margin:10px 0;}");
  client.println(".difficulty{padding:5px 15px; border-radius:15px; display:inline-block; margin:10px 0;}");
  client.println(".diff-1{background:#4CAF50;}");
  client.println(".diff-2{background:#FF9800;}");
  client.println(".diff-3{background:#f44336;}");
  client.println(".winner{color:#FFD700; font-size:32px; text-shadow:0 0 20px #FFD700;}");
  client.println("input[type=text]{width:90%; padding:15px; font-size:18px; border-radius:10px; border:none; margin:10px 0;}");
  client.println("</style>");

  // JavaScript per timer sincronizzato
  if (giocoAvviato && !mostraRisultati && !giocoTerminato) {
    client.println("<script>");
    client.println("let remaining=" + String(remaining) + ";");
    client.println("let total=" + String(durataTurnoCorrente) + ";");
    client.println("function updateTimer(){");
    client.println("  remaining-=100;");
    client.println("  if(remaining<=0){location.reload();return;}");
    client.println("  let sec=Math.ceil(remaining/1000);");
    client.println("  let el=document.getElementById('timer');");
    client.println("  let bar=document.getElementById('progressBar');");
    client.println("  if(el){");
    client.println("    el.innerHTML=sec;");
    client.println("    el.className='timer'+(sec<=5?' danger':(sec<=10?' warning':''));");
    client.println("  }");
    client.println("  if(bar){bar.style.width=(remaining/total*100)+'%';}");
    client.println("}");
    client.println("setInterval(updateTimer,100);");
    client.println("</script>");
  }

  // Auto-refresh durante risultati
  if (mostraRisultati && !giocoTerminato) {
    client.println("<script>");
    client.println("setTimeout(()=>{location.reload();},4000);");
    client.println("</script>");
  }

  client.println("</head><body><div class='card'>");

  bool haRisposto = (g == 1 ? g1Risposto : g2Risposto);

  // --- SCHERMATA FINE GIOCO ---
  if (giocoTerminato) {
    client.println("<h1>🏆 PARTITA TERMINATA! 🏆</h1>");
    client.println("<hr>");
   
    String vincitore;
    if (puntiG1 > puntiG2) {
      vincitore = nomeG1;
      client.println("<p class='winner'>VINCE " + nomeG1 + "!</p>");
    } else if (puntiG2 > puntiG1) {
      vincitore = nomeG2;
      client.println("<p class='winner'>VINCE " + nomeG2 + "!</p>");
    } else {
      client.println("<p class='winner'>PAREGGIO!</p>");
    }
   
    client.println("<div class='score'>");
    client.println("<p>" + nomeG1 + ": <strong>" + String(puntiG1) + "</strong> punti</p>");
    client.println("<p>" + nomeG2 + ": <strong>" + String(puntiG2) + "</strong> punti</p>");
    client.println("</div>");
   
    client.println("<a class='btn' href='/g" + String(g) + "?reset=1'>NUOVA PARTITA</a>");
  }
  // --- CONFIGURAZIONE INIZIALE ---
  else if (!giocoAvviato) {
    String nomeCorrente = (g == 1 ? nomeG1 : nomeG2);
    bool pronto = (g == 1 ? g1Pronto : g2Pronto);
   
    client.println("<h1>👋 Benvenuto!</h1>");
    client.println("<h2>Giocatore " + String(g) + ": " + nomeCorrente + "</h2>");
   
    client.println("<form method='GET'>");
    client.println("<input type='text' name='n" + String(g) + "' placeholder='Inserisci il tuo nome'>");
    client.println("<br><input type='submit' value='SALVA NOME' class='btn'>");
    client.println("</form>");
   
    if (!pronto) {
      client.println("<br><a class='btn' href='/g" + String(g) + "?p" + String(g) + "=1' style='background:#28a745;'>✓ SONO PRONTO</a>");
    } else {
      client.println("<h3 style='color:#28a745;'>✓ Sei pronto!</h3>");
      client.println("<p>Attendi l'avversario...</p>");
    }
   
    // Stato avversario
    bool avversarioPronto = (g == 1 ? g2Pronto : g1Pronto);
    String nomeAvversario = (g == 1 ? nomeG2 : nomeG1);
    if (avversarioPronto) {
      client.println("<p style='color:#28a745;'>" + nomeAvversario + " è pronto!</p>");
    }
  }
  // --- SCHERMATA RISULTATI ---
  else if (mostraRisultati) {
    client.println("<h1>⏱️ TEMPO SCADUTO!</h1>");
    client.println("<h2>Risposta corretta:</h2>");
    client.println("<h2 style='color:#ffc107; font-size:28px;'>" + String(database[domandaCorrente].risposta) + "</h2>");
    client.println("<hr>");
    client.println("<p>Domanda " + String(numeroDomanda) + "/" + String(MAX_DOMANDE_PARTITA) + "</p>");
    client.println("<div class='score'>");
    client.println("<p>" + nomeG1 + ": " + String(puntiG1) + " pts</p>");
    client.println("<p>" + nomeG2 + ": " + String(puntiG2) + " pts</p>");
    client.println("</div>");
    client.println("<p style='color:#888;'>Prossima domanda tra pochi secondi...</p>");
  }
  // --- DOMANDA ATTIVA ---
  else {
    // Header con info partita
    client.println("<p>Domanda " + String(numeroDomanda) + "/" + String(MAX_DOMANDE_PARTITA) + "</p>");
   
    // Difficoltà con colore
    int diff = database[domandaCorrente].difficolta;
    String diffLabel = (diff == 1 ? "FACILE" : (diff == 2 ? "MEDIA" : "DIFFICILE"));
    client.println("<span class='difficulty diff-" + String(diff) + "'>" + diffLabel + "</span>");
   
    // Timer grande
    client.println("<div class='timer' id='timer'>" + String(sec) + "</div>");
   
    // Barra progresso
    int percentuale = (remaining * 100) / durataTurnoCorrente;
    client.println("<div class='progress'><div class='progress-bar' id='progressBar' style='width:" + String(percentuale) + "%;'></div></div>");
   
    // Domanda
    client.println("<h2 style='color:#00d4ff; margin:20px 0;'>" + String(database[domandaCorrente].testo) + "</h2>");

    if (!haRisposto) {
      client.println("<form method='GET'>");
      client.println("<input type='text' name='v" + String(g) + "' placeholder='Scrivi la risposta...' autofocus autocomplete='off'>");
      client.println("<br><input type='submit' value='INVIA RISPOSTA' class='btn'>");
      client.println("</form>");
    } else {
      client.println("<h3 style='color:#28a745;'>✓ Risposta inviata!</h3>");
      client.println("<p>Attendi la fine del tempo...</p>");
    }
   
    // Punteggi in basso
    client.println("<hr><p style='font-size:14px;'>" + nomeG1 + ": " + String(puntiG1) + " | " + nomeG2 + ": " + String(puntiG2) + "</p>");
  }

  client.println("</div></body></html>");
}

// --- LOOP ---
void loop() {
  // --- LCD UPDATE ---
  if (giocoTerminato) {
    lcd.setCursor(0, 0);
    lcd.print("GIOCO FINITO!   ");
    lcd.setCursor(0, 1);
    if (puntiG1 > puntiG2) {
      lcd.print(nomeG1.substring(0, 8) + " VINCE! ");
    } else if (puntiG2 > puntiG1) {
      lcd.print(nomeG2.substring(0, 8) + " VINCE! ");
    } else {
      lcd.print("PAREGGIO!       ");
    }
  }
  else if (giocoAvviato && !mostraRisultati) {
    unsigned long elapsed = millis() - inizioTurno;
    unsigned long remaining = (durataTurnoCorrente > elapsed) ? (durataTurnoCorrente - elapsed) : 0;
    int sec = remaining / 1000;

    lcd.setCursor(0, 0);
    lcd.print("Q");
    lcd.print(numeroDomanda);
    lcd.print("/");
    lcd.print(MAX_DOMANDE_PARTITA);
    lcd.print(" T:");
    if (sec < 10) lcd.print(" ");
    lcd.print(sec);
    lcd.print("s  ");
   
    lcd.setCursor(0, 1);
    lcd.print(nomeG1.substring(0, 4) + ":" + String(puntiG1));
    lcd.print(" ");
    lcd.print(nomeG2.substring(0, 4) + ":" + String(puntiG2));
  }
  else if (giocoAvviato && mostraRisultati) {
    lcd.setCursor(0, 0);
    lcd.print("   RISPOSTA:    ");
    lcd.setCursor(0, 1);
    String risp = database[domandaCorrente].risposta;
    lcd.print(risp.substring(0, 16));
  }
  else {
    lcd.setCursor(0, 0);
    lcd.print("In attesa...    ");
    lcd.setCursor(0, 1);
    lcd.print("Connetti i tel. ");
  }

  // --- GESTIONE TRANSIZIONI ---
  if (giocoAvviato && !mostraRisultati && !giocoTerminato) {
    unsigned long elapsed = millis() - inizioTurno;
    if (elapsed >= durataTurnoCorrente || (g1Risposto && g2Risposto)) {
      mostraRisultati = true;
      inizioRisultati = millis();
    }
  }

  // Dopo 4s di risultati → nuova domanda
  if (mostraRisultati && !giocoTerminato && (millis() - inizioRisultati >= durataRisultati)) {
    nuovaDomanda();
  }

  // --- SERVER ---
  WiFiClient client = server.available();
  if (client) {
    String req = client.readStringUntil('\r');
    client.readStringUntil('\n');

    // Reset partita
    if (req.indexOf("reset=1") > 0) {
      resetPartita();
    }

    // Nomi
    int n1Pos = req.indexOf("n1=");
    if (n1Pos > 0) {
      int endPos = req.indexOf("&", n1Pos);
      if (endPos < 0) endPos = req.indexOf(" ", n1Pos);
      if (endPos > n1Pos + 3) {
        nomeG1 = req.substring(n1Pos + 3, endPos);
        nomeG1.replace("+", " ");
        nomeG1.replace("%20", " ");
        nomeG1.trim();
        if (nomeG1.length() == 0) nomeG1 = "G1";
      }
    }
   
    int n2Pos = req.indexOf("n2=");
    if (n2Pos > 0) {
      int endPos = req.indexOf("&", n2Pos);
      if (endPos < 0) endPos = req.indexOf(" ", n2Pos);
      if (endPos > n2Pos + 3) {
        nomeG2 = req.substring(n2Pos + 3, endPos);
        nomeG2.replace("+", " ");
        nomeG2.replace("%20", " ");
        nomeG2.trim();
        if (nomeG2.length() == 0) nomeG2 = "G2";
      }
    }

    // Pronti iniziali
    if (req.indexOf("p1=1") > 0) g1Pronto = true;
    if (req.indexOf("p2=1") > 0) g2Pronto = true;

    // Risposte (solo durante domanda attiva)
    if (giocoAvviato && !mostraRisultati && !giocoTerminato) {
      int v1Pos = req.indexOf("v1=");
      if (v1Pos > 0 && !g1Risposto) {
        int endPos = req.indexOf("&", v1Pos);
        if (endPos < 0) endPos = req.indexOf(" ", v1Pos);
        if (endPos > v1Pos + 3) {
          String r = req.substring(v1Pos + 3, endPos);
          r.toLowerCase();
          r.replace("+", " ");
          r.replace("%20", " ");
          r.trim();
          if (r == database[domandaCorrente].risposta) {
            puntiG1 += calcolaPunti();
          }
          g1Risposto = true;
        }
      }

      int v2Pos = req.indexOf("v2=");
      if (v2Pos > 0 && !g2Risposto) {
        int endPos = req.indexOf("&", v2Pos);
        if (endPos < 0) endPos = req.indexOf(" ", v2Pos);
        if (endPos > v2Pos + 3) {
          String r = req.substring(v2Pos + 3, endPos);
          r.toLowerCase();
          r.replace("+", " ");
          r.replace("%20", " ");
          r.trim();
          if (r == database[domandaCorrente].risposta) {
            puntiG2 += calcolaPunti();
          }
          g2Risposto = true;
        }
      }
    }

    // Avvio gioco quando entrambi pronti
    if (g1Pronto && g2Pronto && !giocoAvviato && !giocoTerminato) {
      giocoAvviato = true;
      nuovaDomanda();
    }

    // Determina quale giocatore
    int g = (req.indexOf("/g1") >= 0) ? 1 : 2;
    inviaPagina(client, g);
   
    delay(1);
    client.stop();
  }
}

