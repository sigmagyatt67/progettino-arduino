// --- CONFIGURAZIONE PARTITA ---
const int MAX_DOMANDE_PARTITA = 15;
const unsigned long durataRisultati = 4000;  // 4s schermata risposta

// Tempo in base alla difficoltà (in ms)
unsigned long getDurataTurno(int difficolta) {
  switch(difficolta) {
    case 1: return 10000;  // 10s facile
    case 2: return 15000;  // 15s media
    case 3: return 20000;  // 20s difficile
    default: return 15000;
  }
}

// --- STATO ---
int domandaCorrente = 0;
int numeroDomanda = 0;  // Contatore domande fatte (0-14)
int domandeGiaFatte[MAX_DOMANDE_PARTITA];  // Per evitare ripetizioni

String nomeG1 = "G1", nomeG2 = "G2";
int puntiG1 = 0, puntiG2 = 0;

bool g1Pronto = false, g2Pronto = false;
bool giocoAvviato = false;
bool giocoTerminato = false;

bool g1Risposto = false, g2Risposto = false;
bool mostraRisultati = false;

unsigned long inizioTurno = 0;
unsigned long inizioRisultati = 0;
unsigned long durataTurnoCorrente = 15000;

// --- SELEZIONE DOMANDA CASUALE NON RIPETUTA ---
int selezionaDomandaCasuale() {
  int tentativo;
  bool giaUsata;
 
  do {
    tentativo = random(0, numDomande);
    giaUsata = false;
    for (int i = 0; i < numeroDomanda; i++) {
      if (domandeGiaFatte[i] == tentativo) {
        giaUsata = true;
        break;
      }
    }
  } while (giaUsata && numeroDomanda < numDomande);
 
  return tentativo;
}

// --- NUOVA DOMANDA ---
void nuovaDomanda() {
  // Controlla se il gioco è finito
  if (numeroDomanda >= MAX_DOMANDE_PARTITA) {
    giocoTerminato = true;
    mostraRisultati = false;
    return;
  }
 
  domandaCorrente = selezionaDomandaCasuale();
  domandeGiaFatte[numeroDomanda] = domandaCorrente;
  numeroDomanda++;
 
  // Imposta durata in base alla difficoltà
  durataTurnoCorrente = getDurataTurno(database[domandaCorrente].difficolta);
 
  g1Risposto = false;
  g2Risposto = false;
  mostraRisultati = false;
  inizioTurno = millis();
 
  lcd.clear();
}

// --- CALCOLO PUNTI ---
int calcolaPunti() {
  int base = 400 + (database[domandaCorrente].difficolta * 100);
  unsigned long tempoImpiegato = millis() - inizioTurno;
  // Bonus proporzionale al tempo risparmiato
  int bonus = (durataTurnoCorrente - tempoImpiegato) * 500 / durataTurnoCorrente;
  return base + (bonus > 0 ? bonus : 0);
}

// --- RESET PARTITA ---
void resetPartita() {
  numeroDomanda = 0;
  puntiG1 = 0;
  puntiG2 = 0;
  g1Pronto = false;
  g2Pronto = false;
  giocoAvviato = false;
  giocoTerminato = false;
  g1Risposto = false;
  g2Risposto = false;
  mostraRisultati = false;
}

// --- SETUP ---
void setup() {
  Serial.begin(115200);
  lcd.begin(16, 2);
  lcd.print("WiFi Loading...");
  delay(1500);

  WiFi.begin(ssid, pass);
  while (WiFi.status() != WL_CONNECTED) {
    Serial.println("Connessione in corso...");
    delay(500);
  }

  server.begin();
  randomSeed(analogRead(0));

  Serial.print("Indirizzo IP per giocare: ");
  Serial.println(WiFi.localIP());

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("IP:");
  lcd.setCursor(0, 1);
  lcd.print(WiFi.localIP());
}

// --- PAGINA WEB ---
void inviaPagina(WiFiClient &client, int g) {
  unsigned long elapsed = millis() - inizioTurno;
  unsigned long remaining = (durataTurnoCorrente > elapsed) ? (durataTurnoCorrente - elapsed) : 0;
  int sec = remaining / 1000;

  client.println("HTTP/1.1 200 OK");
