#include "WiFiS3.h

//password e nome wifi
char ssid[] = "iPhone19 Pro Max";
char pass[] = "12345678";

// Server Web
WiFiServer server(80);

// Dati giocatori
String nomeG1 = "Giocatore 1";
String valoreG1 = "";
String nomeG2 = "Giocatore 2";
String valoreG2 = "";

// --- LISTA DOMANDE E RISPOSTE CORRETTE ---
String domande[] = {
  "Quanto fa 5 + 3?",
  "Qual'e' la radice di 121?",
  "Numero piu' grande con 3 cifre?",
  "Quanto fa 10 - 4?",
  "Qual e' la capitale d'Italia?"
};

String risposteCorrette[] = {
  "8",
  "11",
  "999",
  "6",
  "roma"
};

int numeroDomande = sizeof(domande) / sizeof(domande[0]);

// Stato del gioco
int domandaCorrente = 0;
bool domandaAttiva = true;

void nuovaDomanda() {
  domandaCorrente = random(0, numeroDomande);
  domandaAttiva = true;
  valoreG1 = "";
  valoreG2 = "";

  Serial.println("\n=== NUOVA DOMANDA ===");
  Serial.println(domande[domandaCorrente]);
  Serial.println("=====================\n");
}

void inviaPaginaGiocatore(WiFiClient &client, int g) {
  client.println("HTTP/1.1 200 OK");
  client.println("Content-type:text/html");
  client.println("Connection: close");
  client.println();

  client.println("<html><body style='text-align:center;font-family:sans-serif;'>");
  client.println("<h1>Gioco a Domande</h1>");
  client.println("<h2>Domanda attuale:</h2>");
  client.println("<h3>" + domande[domandaCorrente] + "</h3>");

  if (g == 1) {
    client.println("<h2 style='color:red;'>" + nomeG1 + "</h2>");
    client.println("<form action='/' method='get'>Nome: <input type='text' name='n1'><input type='submit' value='OK'></form><br>");
    client.println("<form action='/' method='get'>Risposta: <input type='text' name='v1'><input type='submit' value='INVIA'></form>");
  }

  if (g == 2) {
    client.println("<h2 style='color:blue;'>" + nomeG2 + "</h2>");
    client.println("<form action='/' method='get'>Nome: <input type='text' name='n2'><input type='submit' value='OK'></form><br>");
    client.println("<form action='/' method='get'>Risposta: <input type='text' name='v2'><input type='submit' value='INVIA'></form>");
  }

  client.println("</body></html>");
}

void inviaPaginaHome(WiFiClient &client) {
  client.println("HTTP/1.1 200 OK");
  client.println("Content-type:text/html");
  client.println("Connection: close");
  client.println();

  client.println("<html><body style='text-align:center;font-family:sans-serif;'>");
  client.println("<h1>Benvenuto nel gioco</h1>");
  client.println("<a href='/?g=1'>Giocatore 1</a><br><br>");
  client.println("<a href='/?g=2'>Giocatore 2</a>");
  client.println("</body></html>");
}

void controllaRisposta(String nome, String risposta) {
  if (!domandaAttiva) return;

  risposta.toLowerCase();   // CORRETTO per UNO R4 WiFi

  if (risposta == risposteCorrette[domandaCorrente]) {

    domandaAttiva = false;

    Serial.println("====================================");
    Serial.println(" RISPOSTA CORRETTA DI: " + nome);

    delay(1000);
    Serial.println("pronti a una nuova domanda?");
    delay(1000);
    Serial.print("3 ");
    delay(500);
    Serial.print("2 ");
    delay(500);
    Serial.println("1...");
    delay(400);

    nuovaDomanda();
  }
}


void setup() {
  Serial.begin(115200);
  while (!Serial) {}

  Serial.print("Connettendo a ");
  Serial.println(ssid);
  WiFi.begin(ssid, pass);

  while (WiFi.status() != WL_CONNECTED) {
    delay(100);
    Serial.print(".");
  }

  Serial.println("\n--- CONNESSO! ---");
  Serial.print("Apri nel browser: http://");
  Serial.println(WiFi.localIP());

  randomSeed(analogRead(A0));

  Serial.println("Avete 10 secondi per cambiare nome...");
  delay(10000);

  nuovaDomanda();
  server.begin();
}

void loop() {
  WiFiClient client = server.available();

  if (client) {
    String richiesta = "";

    while (client.connected()) {
      if (client.available()) {
        char c = client.read();
        richiesta += c;

        if (c == '\n') {

          // PAGINA G1
          if (richiesta.indexOf("GET /?g=1") >= 0) {
            inviaPaginaGiocatore(client, 1);
            break;
          }

          // PAGINA G2
          if (richiesta.indexOf("GET /?g=2") >= 0) {
            inviaPaginaGiocatore(client, 2);
            break;
          }

          // CAMBIO NOME G1
          if (richiesta.indexOf("GET /?n1=") >= 0) {
            int inizio = richiesta.indexOf("n1=") + 3;
            int fine = richiesta.indexOf(' ', inizio);
            nomeG1 = richiesta.substring(inizio, fine);
            Serial.println("G1 cambia nome in: " + nomeG1);
          }

          // RISPOSTA G1
          if (richiesta.indexOf("GET /?v1=") >= 0) {
            int inizio = richiesta.indexOf("v1=") + 3;
            int fine = richiesta.indexOf(' ', inizio);
            valoreG1 = richiesta.substring(inizio, fine);
            Serial.println(nomeG1 + " risponde: " + valoreG1);
            controllaRisposta(nomeG1, valoreG1);
          }

          // CAMBIO NOME G2
          if (richiesta.indexOf("GET /?n2=") >= 0) {
            int inizio = richiesta.indexOf("n2=") + 3;
            int fine = richiesta.indexOf(' ', inizio);
            nomeG2 = richiesta.substring(inizio, fine);
            Serial.println("G2 cambia nome in: " + nomeG2);
          }

          // RISPOSTA G2
          if (richiesta.indexOf("GET /?v2=") >= 0) {
            int inizio = richiesta.indexOf("v2=") + 3;
            int fine = richiesta.indexOf(' ', inizio);
            valoreG2 = richiesta.substring(inizio, fine);
            Serial.println(nomeG2 + " risponde: " + valoreG2);
            controllaRisposta(nomeG2, valoreG2);
          }

          // HOME PAGE
          if (richiesta == "\r\n" || richiesta == "\n") {
            inviaPaginaHome(client);
            break;
          }

          richiesta = "";
        }
      }
    }

    delay(10);
    client.stop();
  }
}
