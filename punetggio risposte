int numeroDomande = 61;
int domandaCorrente = 0;

void nuovaDomanda() {
  domandaCorrente = random(0, numeroDomande);
  haRispostoG1 = false; haRispostoG2 = false;
  puntiTurnoG1 = 0; puntiTurnoG2 = 0;
  mostraRisultati = false;
  tempoInizioDomanda = millis();
}

int calcolaPunti() {
  unsigned long ms = millis() - tempoInizioDomanda;
  int bonus = 500 - (ms / 30); 
  return 500 + (bonus > 0 ? bonus : 0);
}

void inviaPagina(WiFiClient &client, int g) {
  client.println("HTTP/1.1 200 OK\nContent-type:text/html\n\n<html><body style='text-align:center; font-family:sans-serif;'>");
  
  if (!mostraRisultati) {
    long resto = durataTurno - (millis() - tempoInizioDomanda);
    client.println("<h1 style='color:red;'>TIMER: " + String(resto > 0 ? resto/1000 : 0) + "s</h1>");
    client.println("<h2>" + domande[domandaCorrente] + "</h2>");
    if (!((g==1?haRispostoG1:haRispostoG2))) {
      client.println("<form method='get'><input type='hidden' name='g' value='"+String(g)+"'><input type='text' name='v"+String(g)+"' autofocus style='padding:10px;'><input type='submit' value='INVIA' style='padding:10px;'></form>");
    } else {
      client.println("<h3 style='color:blue;'>Risposta ricevuta! Attendi gli altri...</h3>");
    }
    client.println("<script>setTimeout(function(){location.reload();}, 1000);</script>");
  } else {
    client.println("<h1>TEMPO SCADUTO!</h1><h2>La risposta era: " + risposteCorrette[domandaCorrente] + "</h2><hr>");
    client.println("<p><b>" + nomeG1 + ":</b> " + String(puntiTotaliG1) + " (+" + String(puntiTurnoG1) + ")</p>");
    client.println("<p><b>" + nomeG2 + ":</b> " + String(puntiTotaliG2) + " (+" + String(puntiTurnoG2) + ")</p>");
    client.println("<script>setTimeout(function(){location.reload();}, 5000);</script>");
  }
  client.println("</body></html>");
}

void setup() {
  Serial.begin(115200);
  WiFi.begin(ssid, pass);
  while (WiFi.status() != WL_CONNECTED) delay(500);
  server.begin();
  randomSeed(analogRead(0));
  nuovaDomanda();
}

void loop() {
  if (!mostraRisultati && (millis() - tempoInizioDomanda >= durataTurno || (haRispostoG1 && haRispostoG2))) {
    mostraRisultati = true;
    puntiTotaliG1 += puntiTurnoG1;
    puntiTotaliG2 += puntiTurnoG2;
    tempoInizioDomanda = millis(); 
  }

  if (mostraRisultati && (millis() - tempoInizioDomanda >= 5000)) nuovaDomanda();

  WiFiClient client = server.available();
  if (client) {
    String req = client.readStringUntil('\r');
    if (req.indexOf("GET /?g=1") >= 0 && req.indexOf("v1=") == -1) inviaPagina(client, 1);
    else if (req.indexOf("GET /?g=2") >= 0 && req.indexOf("v2=") == -1) inviaPagina(client, 2);
    else if (req.indexOf("v1=") >= 0 && !haRispostoG1) {
      int start = req.indexOf("v1=") + 3;
      int end = req.indexOf(" ", start);
      String r = req.substring(start, end);
      r.toLowerCase(); r.replace("+", " ");
      if (r == risposteCorrette[domandaCorrente]) puntiTurnoG1 = calcolaPunti();
      haRispostoG1 = true;
      inviaPagina(client, 1);
    }
    else if (req.indexOf("v2=") >= 0 && !haRispostoG2) {
      int start = req.indexOf("v2=") + 3;
      int end = req.indexOf(" ", start);
      String r = req.substring(start, end);
      r.toLowerCase(); r.replace("+", " ");
      if (r == risposteCorrette[domandaCorrente]) puntiTurnoG2 = calcolaPunti();
      haRispostoG2 = true;
      inviaPagina(client, 2);
    }
    else { inviaPagina(client, 1); }
    client.stop();
  }
}

