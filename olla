void controllaRisposta(String nome, String risposta) {
  if (!domandaAttiva) return;

  risposta.toLowerCase();   // CORRETTO per UNO R4 WiFi

  if (risposta == risposteCorrette[domandaCorrente]) {

    domandaAttiva = false;

    Serial.println("====================================");
    Serial.println(" RISPOSTA CORRETTA DI: " + nome);

    delay(1000);
    Serial.println("pronti a una nuova domanda?");
    delay(1000);
    Serial.print("3 ");
    delay(500);
    Serial.print("2 ");
    delay(500);
    Serial.println("1...");
    delay(400);

    nuovaDomanda();
  }
}


void setup() {
  Serial.begin(115200);
  while (!Serial) {}

  Serial.print("Connettendo a ");
  Serial.println(ssid);
  WiFi.begin(ssid, pass);

  while (WiFi.status() != WL_CONNECTED) {
    delay(100);
    Serial.print(".");
  }

  Serial.println("\n--- CONNESSO! ---");
  Serial.print("Apri nel browser: http://");
  Serial.println(WiFi.localIP());

  randomSeed(analogRead(A0));

  Serial.println("Avete 10 secondi per cambiare nome...");
  delay(10000);

  nuovaDomanda();
  server.begin();
}

void loop() {
  WiFiClient client = server.available();

  if (client) {
    String richiesta = "";

    while (client.connected()) {
      if (client.available()) {
        char c = client.read();
        richiesta += c;

        if (c == '\n') {

          // PAGINA G1
          if (richiesta.indexOf("GET /?g=1") >= 0) {
            inviaPaginaGiocatore(client, 1);
            break;
          }

          // PAGINA G2
          if (richiesta.indexOf("GET /?g=2") >= 0) {
            inviaPaginaGiocatore(client, 2);
            break;
          }

          // CAMBIO NOME G1
          if (richiesta.indexOf("GET /?n1=") >= 0) {
            int inizio = richiesta.indexOf("n1=") + 3;
            int fine = richiesta.indexOf(' ', inizio);
            nomeG1 = richiesta.substring(inizio, fine);
            Serial.println("G1 cambia nome in: " + nomeG1);
          }

          // RISPOSTA G1
          if (richiesta.indexOf("GET /?v1=") >= 0) {
            int inizio = richiesta.indexOf("v1=") + 3;
            int fine = richiesta.indexOf(' ', inizio);
            valoreG1 = richiesta.substring(inizio, fine);
            Serial.println(nomeG1 + " risponde: " + valoreG1);
            controllaRisposta(nomeG1, valoreG1);
          }

          // CAMBIO NOME G2
          if (richiesta.indexOf("GET /?n2=") >= 0) {
            int inizio = richiesta.indexOf("n2=") + 3;
            int fine = richiesta.indexOf(' ', inizio);
            nomeG2 = richiesta.substring(inizio, fine);
            Serial.println("G2 cambia nome in: " + nomeG2);
          }

          // RISPOSTA G2
          if (richiesta.indexOf("GET /?v2=") >= 0) {
            int inizio = richiesta.indexOf("v2=") + 3;
            int fine = richiesta.indexOf(' ', inizio);
            valoreG2 = richiesta.substring(inizio, fine);
            Serial.println(nomeG2 + " risponde: " + valoreG2);
            controllaRisposta(nomeG2, valoreG2);
          }

          // HOME PAGE
          if (richiesta == "\r\n" || richiesta == "\n") {
            inviaPaginaHome(client);
            break;
          }

          richiesta = "";
        }
      }
    }

    delay(10);
    client.stop();
  }
}
