  if (g == 1) {
    client.println("<h2 style='color:red;'>" + nomeG1 + "</h2>");
    client.println("<form action='/' method='get'>Nome: <input type='text' name='n1'><input type='submit' value='OK'></form><br>");
    client.println("<form action='/' method='get'>Risposta: <input type='text' name='v1'><input type='submit' value='INVIA'></form>");
  }

  if (g == 2) {
    client.println("<h2 style='color:blue;'>" + nomeG2 + "</h2>");
